{
  "name": "@naeemba/next-starter",
  "version": "0.7.0",
  "description": "Opinionated Next.js + Drizzle + Better Auth starter, shipped as a versioned package.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/naeemba/next-typescript-starter.git"
  },
  "homepage": "https://github.com/naeemba/next-typescript-starter#readme",
  "bugs": {
    "url": "https://github.com/naeemba/next-typescript-starter/issues"
  },
  "type": "module",
  "sideEffects": false,
  "private": false,
  "keywords": [
    "nextjs",
    "next-starter",
    "better-auth",
    "drizzle",
    "drizzle-orm",
    "postgres",
    "magic-link",
    "passkey",
    "webauthn",
    "google-oauth",
    "auth",
    "starter"
  ],
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "next-starter": "./bin/cli.mjs"
  },
  "files": [
    "bin",
    "dist",
    "README.md",
    "UPGRADING.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "workspaces": [
    "examples/basic"
  ],
  "exports": {
    "./auth": {
      "types": "./dist/auth/index.d.ts",
      "default": "./dist/auth/index.js"
    },
    "./auth-route": {
      "types": "./dist/auth-route/index.d.ts",
      "default": "./dist/auth-route/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "default": "./dist/client/index.js"
    },
    "./schema": {
      "types": "./dist/schema/index.d.ts",
      "default": "./dist/schema/index.js"
    },
    "./db": {
      "types": "./dist/db/index.d.ts",
      "default": "./dist/db/index.js"
    },
    "./email": {
      "types": "./dist/email/index.d.ts",
      "default": "./dist/email/index.js"
    },
    "./proxy": {
      "types": "./dist/proxy/index.d.ts",
      "default": "./dist/proxy/index.js"
    },
    "./pages/sign-in": {
      "types": "./dist/pages/sign-in/index.d.ts",
      "default": "./dist/pages/sign-in/index.js"
    },
    "./pages/passkey-manager": {
      "types": "./dist/pages/passkey-manager/index.d.ts",
      "default": "./dist/pages/passkey-manager/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "default": "./dist/server/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build",
    "preversion": "npm run typecheck && npm run test && npm run build",
    "version": "npm run changelog && git add CHANGELOG.md",
    "postversion": "git push --follow-tags",
    "changelog": "node scripts/regenerate-changelog.mjs",
    "release:patch": "node scripts/release-preflight.mjs && npm version patch -m \"chore(release): %s\"",
    "release:minor": "node scripts/release-preflight.mjs && npm version minor -m \"chore(release): %s\"",
    "release:major": "node scripts/release-preflight.mjs && npm version major -m \"chore(release): %s\""
  },
  "dependencies": {
    "better-auth": "^1.6.16",
    "drizzle-orm": "^0.45.2",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "@better-auth/passkey": ">=1.6.0",
    "@react-email/components": ">=1.0.0",
    "@react-email/render": ">=2.0.0",
    "next": ">=16.0.0",
    "postgres": ">=3.4.0",
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0",
    "resend": ">=6.0.0"
  },
  "peerDependenciesMeta": {
    "@better-auth/passkey": {
      "optional": true
    },
    "@react-email/components": {
      "optional": true
    },
    "@react-email/render": {
      "optional": true
    },
    "postgres": {
      "optional": true
    },
    "resend": {
      "optional": true
    }
  },
  "devDependencies": {
    "@better-auth/passkey": "^1.6.16",
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.0.8",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.0",
    "conventional-changelog-cli": "^5.0.0",
    "jsdom": "^29.1.1",
    "next": "^16.2.9",
    "postgres": "^3.4.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "resend": "^6.12.4",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "publishConfig": {
    "access": "public"
  }
}
